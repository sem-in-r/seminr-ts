digraph G {

// ----------------------
// General graph settings
// ----------------------
graph [
charset = "UTF-8",
layout = dot,
label = "Custom theme",
fontsize = 30,
fontcolor = black,
fontname = helvetica,
rankdir = LR,
labelloc = t,
splines = TRUE
bgcolor = white
]

// --------------------
// The structural model
// --------------------
subgraph sm {
rankdir = LR;
node [
shape = ellipse,
color = black,
fillcolor = lightcyan,
style = filled,
fontsize = 12,
fontcolor = black,
height = 1.03933333333333,
width = 1.27083333333333,
fontname = helvetica,
fixedsize = true
]
"Image" [label=<<B>Image </B>>, shape = ellipse]
"Expectation" [label=<<B>Expectation </B><BR /><FONT POINT-SIZE='10'>adj. R^2 = 0.74</FONT>>, shape = ellipse]
"Quality" [label=<<B>Quality </B><BR /><FONT POINT-SIZE='10'>adj. R^2 = 0.76</FONT>>, shape = ellipse]
"Value" [label=<<B>Value </B><BR /><FONT POINT-SIZE='10'>adj. R^2 = 0.45</FONT>>, shape = ellipse]
"Satisfaction" [label=<<B>Satisfaction </B><BR /><FONT POINT-SIZE='10'>adj. R^2 = 0.93</FONT>>, shape = ellipse]
"Complaints" [label=<<B>Complaints </B><BR /><FONT POINT-SIZE='10'>adj. R^2 = 0.35</FONT>>, shape = ellipse]
"Loyalty" [label=<<B>Loyalty </B><BR /><FONT POINT-SIZE='10'>adj. R^2 = 0.73</FONT>>, shape = ellipse]
edge [
color = black,
fontsize = 9,
fontcolor = black,
fontname = helvetica,
dir = both,
arrowhead = normal,
arrowtail = none
]
"Image" -> {"Expectation"}[weight = 1, label = < gamma = 0.86<BR /><FONT POINT-SIZE='7'>   </FONT> >, penwidth = 4.8, style = solid, color = black]
"Image" -> {"Satisfaction"}[weight = 1, label = < gamma = 0.15<BR /><FONT POINT-SIZE='7'>   </FONT> >, penwidth = 1.25, style = solid, color = black]
"Image" -> {"Loyalty"}[weight = 1, label = < gamma = -0.09<BR /><FONT POINT-SIZE='7'>   </FONT> >, penwidth = 0.95, style = dashed, color = black]
"Expectation" -> {"Quality"}[weight = 1, label = < beta = 0.87<BR /><FONT POINT-SIZE='7'>   </FONT> >, penwidth = 4.85, style = solid, color = black]
"Expectation" -> {"Value"}[weight = 1, label = < beta = -0.05<BR /><FONT POINT-SIZE='7'>   </FONT> >, penwidth = 0.75, style = dashed, color = black]
"Expectation" -> {"Satisfaction"}[weight = 1, label = < beta = 0.03<BR /><FONT POINT-SIZE='7'>   </FONT> >, penwidth = 0.65, style = solid, color = black]
"Quality" -> {"Value"}[weight = 1, label = < beta = 0.72<BR /><FONT POINT-SIZE='7'>   </FONT> >, penwidth = 4.1, style = solid, color = black]
"Quality" -> {"Satisfaction"}[weight = 1, label = < beta = 0.67<BR /><FONT POINT-SIZE='7'>   </FONT> >, penwidth = 3.85, style = solid, color = black]
"Value" -> {"Satisfaction"}[weight = 1, label = < beta = 0.18<BR /><FONT POINT-SIZE='7'>   </FONT> >, penwidth = 1.4, style = solid, color = black]
"Satisfaction" -> {"Complaints"}[weight = 1, label = < beta = 0.59<BR /><FONT POINT-SIZE='7'>   </FONT> >, penwidth = 3.45, style = solid, color = black]
"Satisfaction" -> {"Loyalty"}[weight = 1, label = < beta = 0.96<BR /><FONT POINT-SIZE='7'>   </FONT> >, penwidth = 5.3, style = solid, color = black]
"Complaints" -> {"Loyalty"}[weight = 1, label = < beta = -0.04<BR /><FONT POINT-SIZE='7'>   </FONT> >, penwidth = 0.7, style = dashed, color = black]
}
