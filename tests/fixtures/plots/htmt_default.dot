graph G {

// ----------------------
// General graph settings
// ----------------------
graph [
charset = "UTF-8",
layout = dot,
label = "HTMT Plot",
fontsize = 24,
fontname = helvetica,
rankdir = LR,
labelloc = t,
ranksep = 0.5,
nodesep = 0.5,
splines = TRUE
]

// --------------------
// The htmt model
// --------------------
node [
shape = ellipse,
color = black,
fillcolor = white,
style = filled,
fontsize = 12,
height = 0.519666666666667,
width = 1.27083333333333,
fontname = helvetica,
fixedsize = true
]
edge [
color = black,
fontsize = 9,
fontname = helvetica,
dir = both,
arrowhead = none,
arrowtail = none
]


}
