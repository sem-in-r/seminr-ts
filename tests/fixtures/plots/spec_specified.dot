color = dimgrey,
fontsize = 7,
fontcolor = black,
fontname = helvetica,
minlen = 1,
dir = both
arrowhead = none
arrowtail = normal
]
"IMAG1" -> {"Image"}[weight = 1000, penwidth = 1.5, style = solid, color = dimgrey]
