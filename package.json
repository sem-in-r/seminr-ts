{
  "name": "@seminr/core",
  "version": "0.1.2",
  "description": "SEM (Structural Equation Modeling) estimation in TypeScript — PLS-SEM and covariance-based SEM (CBSEM/CFA), ported from the seminr R package",
  "author": "Soumya Ray",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sem-in-r/seminr-ts.git"
  },
  "homepage": "https://github.com/sem-in-r/seminr-ts#readme",
  "bugs": {
    "url": "https://github.com/sem-in-r/seminr-ts/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "typecheck:demos": "bun run build && tsc -p demos",
    "smoke:pack": "bun run scripts/smoke-pack.ts",
    "check:parity": "bun run scripts/check-parity.ts",
    "benchmark": "bun run benchmark/run.ts",
    "demo": "bun run build && bun run demos/browser/serve.ts",
    "prepublishOnly": "bun run build && bun test"
  },
  "keywords": [
    "pls-sem",
    "sem",
    "partial-least-squares",
    "structural-equation-modeling",
    "cbsem",
    "cfa",
    "factor-analysis",
    "lavaan",
    "bootstrap",
    "statistics",
    "seminr"
  ],
  "license": "GPL-3.0-only",
  "peerDependencies": {
    "@hpcc-js/wasm-graphviz": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@hpcc-js/wasm-graphviz": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hpcc-js/wasm-graphviz": "^1.24.1",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
