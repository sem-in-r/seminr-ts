{
  "name": "semints",
  "version": "0.1.0",
  "description": "PLS-SEM (Partial Least Squares Structural Equation Modeling) estimation in TypeScript, ported from the seminr R package",
  "author": "Soumya Ray",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sem-in-r/semints.git"
  },
  "homepage": "https://github.com/sem-in-r/semints#readme",
  "bugs": {
    "url": "https://github.com/sem-in-r/semints/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit && tsc -p demos",
    "prepublishOnly": "bun run build && bun test"
  },
  "keywords": [
    "pls-sem",
    "sem",
    "partial-least-squares",
    "structural-equation-modeling",
    "statistics",
    "seminr"
  ],
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
